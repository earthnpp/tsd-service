# ── MySQL ──────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=helpdesk
MYSQL_USER=helpdesk_user
MYSQL_PASSWORD=helpdesk_pass

# ── Prisma ─────────────────────────────────────────
DATABASE_URL="mysql://helpdesk_user:helpdesk_pass@db:3306/helpdesk"

# ── Line OA ────────────────────────────────────────
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LIFF_ID=your_liff_id_here

# ── App ────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Security ───────────────────────────────────────
# CORS: ใส่ domain จริงของระบบ (comma-separated) เช่น https://helpdesk.company.com
# ถ้าว่าง = อนุญาตเฉพาะ same-origin (nginx proxy) เท่านั้น
CORS_ORIGIN=

# ── Admin ──────────────────────────────────────────
ADMIN_SECRET=change_this_to_a_strong_secret
JWT_SECRET=change_this_to_a_random_secret_string

# ── Google OAuth (Admin Login) ──────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
# อีเมล Google สำหรับ bootstrap ครั้งแรก (ก่อนเพิ่มใน User Management)
INITIAL_ADMIN_EMAIL=your_admin@gmail.com

# ── Google Calendar (Room Booking) ──────────────────
# Service Account JSON stringify หรือ base64
GOOGLE_CREDENTIALS=
# Calendar ID สำหรับแสดงใน LIFF (optional)
MASTER_CALENDAR_ID=

# ── Optional ───────────────────────────────────────
DAILY_TICKET_LIMIT=3
